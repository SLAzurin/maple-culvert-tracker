{
  "name": "chartmaker",
  "version": "1.0.0",
  "description": "",
  "type": "commonjs",
  "main": "dist/server.js",
  "private": true,
  "scripts": {
    "build": "esbuild src/server.ts --platform=node --outdir=dist --bundle --external:sharp --external:chart.js",
    "build:bin": "pnpm run build && cp $(command -v node) dist/server && node --experimental-sea-config sea-server.json && pnpx postject dist/server NODE_SEA_BLOB dist/sea-server.blob --sentinel-fuse NODE_SEA_FUSE_fce680ab2cc467b6e072b8b5df1996b2"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/SLAzurin/maple-culvert-tracker.git"
  },
  "keywords": [
    "maplestory",
    "culvert"
  ],
  "author": "SLAzurin",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/SLAzurin/maple-culvert-tracker/issues"
  },
  "homepage": "https://github.com/SLAzurin/maple-culvert-tracker#readme",
  "dependencies": {
    "chart.js": "^3.9.1",
    "chartjs-node-canvas": "^4.1.6",
    "chartjs-plugin-datalabels": "^2.2.0",
    "express": "^4.18.2",
    "sharp": "^0.33.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21"
  }
}